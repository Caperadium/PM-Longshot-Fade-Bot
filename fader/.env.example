# EOA private key for signing orders (required for live mode)
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# Wallet address (required for balance reads)
POLYMARKET_USER_ADDRESS=0x_your_wallet_address_here

# Telegram alerting (optional but recommended)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Polygon RPC for on-chain balance/allowance reads (live mode).
# The public default (https://polygon-rpc.com) is frequently rate-limited /
# returns 401, which silently zeroes balance reads and stops the bot trading.
# Use a keyed provider (Alchemy/Infura/etc.). Leave blank to use the default.
POLYGON_RPC_URL=
